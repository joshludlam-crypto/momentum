          <div style={{ display:'flex', justifyContent:'center', gap:8, marginBottom:28, flexWrap:'wrap' }}>
            {STAGES.map((s,i) => (
              <div key={i} style={{ background:'rgba(255,255,255,0.06)', borderRadius:10,
