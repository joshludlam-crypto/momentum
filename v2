      </div>
      <div className={\`toggle \${on?'on':'off'}\`} onClick={onToggle}>
        <div className="toggle-thumb"/>
      </div>
    </div>
  );
}

export default function App() {
  const [screen, setScreen]       = useState('home');
  const [stageIdx, setStageIdx]   = useState(0);
  const [timeLeft, setTimeLeft]   = useState(STAGES[0].duration);
  const [xp, setXp]               = useState(0);
  const [confetti, setConfetti]   = useState(false);
  const [bigWin, setBigWin]       = useState(false);
  const [task, setTask]           = useState('');
  const [soundOn, setSoundOn]     = useState(true);
  const [vibrateOn, setVibrateOn] = useState(true);
  const [notifOK, setNotifOK]     = useState(false);
  const [wakeLockOK, setWakeLockOK] = useState(false);
  const [settings, setSettings]   = useState(false);

  const intervalRef = useRef(null);
  const audioRef    = useRef(null);
  const swRef       = useRef(null);
  const wakeLockRef = useRef(null);

  const stage     = STAGES[stageIdx];
  const prog      = 1 - timeLeft / stage.duration;
  const totalProg = (STAGES.slice(0, stageIdx).reduce((s,st) => s+st.duration, 0)
                    + (stage.duration - timeLeft)) / 3600;
  const circ      = 2 * Math.PI * 90;

  // ── Init ──────────────────────────────────────────
  useEffect(() => {
    audioRef.current = new (window.AudioContext || window.webkitAudioContext)();
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.ready.then(r => { swRef.current = r; });
    }
    if (Notification.permission === 'granted') setNotifOK(true);
  }, []);

  // Re-acquire wake lock when tab regains visibility
  useEffect(() => {
    const onVisible = async () => {
      if (document.visibilityState === 'visible' && screen === 'running') {
        await acquireWakeLock();
      }
    };
    document.addEventListener('visibilitychange', onVisible);
    return () => document.removeEventListener('visibilitychange', onVisible);
  }, [screen]);

  // ── Wake Lock ─────────────────────────────────────
  async function acquireWakeLock() {
    if (!('wakeLock' in navigator)) return;
    try {
      wakeLockRef.current = await navigator.wakeLock.request('screen');
      setWakeLockOK(true);
      wakeLockRef.current.addEventListener('release', () => setWakeLockOK(false));
    } catch(e) { console.log('Wake lock:', e); }
  }

  function releaseWakeLock() {
    if (wakeLockRef.current) { wakeLockRef.current.release(); wakeLockRef.current = null; }
    setWakeLockOK(false);
  }

  // ── Notifications ─────────────────────────────────
  async function askNotifPermission() {
    const p = await Notification.requestPermission();
    setNotifOK(p === 'granted');
    return p === 'granted';
  }

  // ── Fire alert at end of each stage ──────────────
  // Tries three methods in order:
  //   1. Service Worker notification (works in background)
  //   2. Direct Notification API (foreground fallback)
  //   3. window.focus() to bring app to front
  function fireAlert(title, body) {
    const isFinal = stageIdx === STAGES.length - 1;

    // Sound
    if (soundOn && audioRef.current) {
      if (audioRef.current.state === 'suspended') audioRef.current.resume();
      playTone(audioRef.current, isFinal);
    }

    // Vibration (Android / some laptops)
    if (vibrateOn && navigator.vibrate) navigator.vibrate([200,100,200,100,300]);

    // Notification via Service Worker (background-safe)
    if (notifOK && swRef.current?.active) {
      swRef.current.active.postMessage({ type:'STAGE_COMPLETE', title, body, vibrate: vibrateOn });
    } else if (notifOK) {
      // Direct fallback if SW not ready
      new Notification(title, {
        body,
        icon: '/icons/icon-192.png',
        requireInteraction: true,   // stays until dismissed
        tag: 'momentum-stage',
      });
    }

    // Bring window to front (works best when installed as PWA)
    try { window.focus(); } catch(e) {}
  }

  // ── Timer tick ───────────────────────────────────
  useEffect(() => {
    if (screen !== 'running') return;
    intervalRef.current = setInterval(() => {
      setTimeLeft(t => {
        if (t <= 1) {
          clearInterval(intervalRef.current);
          const isFinal = stageIdx === STAGES.length - 1;
          setXp(prev => prev + stage.xp);
          setConfetti(true);
          setTimeout(() => setConfetti(false), 1500);
          fireAlert(
            isFinal ? '🏆 ONE FULL HOUR!' : \`\${stage.emoji} Stage Complete!\`,
            stage.msg
          );
          if (isFinal) { setBigWin(true); releaseWakeLock(); setScreen('done'); }
          else         { setScreen('checkin'); }
          return 0;
        }
        return t - 1;
      });
    }, 1000);
    return () => clearInterval(intervalRef.current);
  }, [screen, stageIdx, soundOn, vibrateOn, notifOK]);

  // ── Actions ──────────────────────────────────────
  async function handleStart() {
    if (audioRef.current?.state === 'suspended') audioRef.current.resume();
    if (!notifOK) await askNotifPermission();
    await acquireWakeLock();
    setScreen('running');
  }

  function continueNext() {
    const n = stageIdx + 1;
    setStageIdx(n); setTimeLeft(STAGES[n].duration); setScreen('running');
  }

  function stopEarly() {
    clearInterval(intervalRef.current); releaseWakeLock(); setScreen('done');
  }

  function reset() {
    releaseWakeLock();
    setScreen('home'); setStageIdx(0); setTimeLeft(STAGES[0].duration);
    setXp(0); setBigWin(false); setTask('');
  }

  // ── Render ───────────────────────────────────────
  return (
    <div style={{ minHeight:'100vh', display:'flex', flexDirection:'column',
                  alignItems:'center', justifyContent:'center',
                  padding:'20px', position:'relative', overflow:'hidden' }}>

